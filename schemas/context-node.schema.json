{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ContextNode",
  "type": "object",
  "required": ["id", "label", "type", "color", "path", "summary", "trust_level", "privacy_level"],
  "properties": {
    "id": { "type": "string" },
    "parent_id": { "type": ["string", "null"] },
    "label": { "type": "string" },
    "type": { "type": "string" },
    "color": { "type": "string", "enum": ["gold","blue","green","red","purple","white","gray","cyan","orange"] },
    "path": { "type": "string" },
    "summary": { "type": "string" },
    "children": { "type": "array", "items": { "type": "string" } },
    "source_paths": { "type": "array", "items": { "type": "string" } },
    "embedding_refs": { "type": "array", "items": { "type": "string" } },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "last_verified": { "type": "string" },
    "verified_by": { "type": "string" },
    "trust_level": { "type": "string", "enum": ["user_verified","source_backed","ai_inferred","disputed","stale","unknown"] },
    "staleness_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "privacy_level": { "type": "string", "enum": ["public","private","sensitive","locked"] },
    "access": { "type": "object" },
    "marker": { "type": "object", "properties": { "kind": { "type": "string" }, "payload": { "type": "string" } } }
  }
}
