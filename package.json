{
  "name": "aurum-recall",
  "version": "0.1.0",
  "description": "AI-native memory: a sovereign, human-readable, self-curating store (library + MCP) + a visual context-routing lattice (ContextQR) with a scannable root QR. Route before you retrieve.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Aurum Nebula LLC",
  "bin": {
    "aurum-recall-mcp": "dist/mcp.js",
    "aurum-recall-lens": "dist/lens-cli.js",
    "aurum-recall-fractal": "dist/fractal-cli.js",
    "aurum-recall-lattice": "dist/lattice/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "SPEC.md",
    "BUILD_PLAN.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test test/*.test.js",
    "typecheck": "tsc --noEmit"
