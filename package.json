    "memory",
    "llm",
    "mcp",
    "sovereign",
    "knowledge-base",
    "context",
    "qr",
    "rag",
    "routing"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3",
    "qrcode": "^1.5.4"
  }
}
