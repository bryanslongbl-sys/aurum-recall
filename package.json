{
  "name": "aurum-recall",
  "version": "0.1.0",
  "description": "Open agent memory: sovereign, human-readable, self-curating. Typed Markdown files + an always-in-context index + [[links]] + trust-decay.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Aurum Nebula LLC",
  "bin": {
    "aurum-recall-mcp": "dist/mcp.js",
    "aurum-recall-lens": "dist/lens-cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "SPEC.md",
    "BUILD_PLAN.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test test/*.test.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "agent",
    "memory",
    "llm",
    "mcp",
    "sovereign",
    "knowledge-base"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
